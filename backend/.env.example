# Server
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=postgres://gradfix:gradfix@localhost:5432/gradfix

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Email (dev: leave blank to log emails to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="GradFix <no-reply@gradfix.app>"

# App URLs (for links in emails)
APP_BASE_URL=http://localhost:5173

# File storage
UPLOAD_DIR=uploads
